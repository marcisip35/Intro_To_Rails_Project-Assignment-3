<!DOCTYPE html>
<html>
  <head>
    <title>Dog Breeds For You</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <%= stylesheet_link_tag "application" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="site-header">
      <div class="header-inner">
        <div class="brand"><%= link_to "Dog Breeds For You", root_path %></div>
          <%= form_with url: breeds_path, method: :get, local: true, class: "header-search-form" do %>
            <%= text_field_tag :query, params[:query], placeholder: "Search breeds", class: "header-search" %>
          <%= select_tag :group_id,
            options_from_collection_for_select(Group.all, :id, :name, params[:group_id]),
            include_blank: "All groups",
            class: "header-group-select" %>
            <%= submit_tag "Search", class: "header-search-btn" %>
          <% end %>
        <nav class="header-nav">
          <%= link_to "Home", root_path %>
          <%= link_to "All Breeds", breeds_path %>
          <%= link_to "About", about_path %>
        </nav>
      </div>
    </header>

    <%= yield %>
  </body>
</html>