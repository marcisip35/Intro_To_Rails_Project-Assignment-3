<h1><%= @breed.name %></h1>

<%= image_tag @breed.image_url, width: 400 %>

<p>Group: <%= @breed.group.name %></p>
<p><%= @breed.reviews.count %> reviews</p>
<p>Average rating: <%= @breed.reviews.average(:rating).round(1) %>/5</p>

<%= link_to "Back to all breeds", breeds_path %>

<h2>Reviews</h2>

<% @breed.reviews.each do |review| %>
  <div>
    <h4><%= review.reviewer_name %></h4>
    <p>Rating: <%= review.rating %>/5</p>
    <p>Playfulness: <%= review.playfulness %>/5</p>
    <p>Affection: <%= review.affection %>/5</p>
    <p>Ease of care: <%= review.ease_of_care %>/5</p>
    <p><%= review.comment %></p>
  </div>
<% end %>